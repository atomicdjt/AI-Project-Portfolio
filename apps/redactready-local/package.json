{
  "name": "redactready-local",
  "private": true,
  "version": "1.0.0",
  "description": "A local-first assistive privacy review tool for PDFs, images, text, and CSV files.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "preview": "npm run build && vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.394",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.0.15"
  }
}
