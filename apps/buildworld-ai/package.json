{
  "name": "buildworld-ai",
  "private": true,
  "version": "0.0.0",
  "description": "A visual simulation lab for graph-based systems, cascade analysis, SSI scoring, and exportable scenario reports.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5183",
    "build": "tsc -b && vite build",
